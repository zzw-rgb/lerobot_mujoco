<!--
  Franka Panda 桌面操作场景（脚手架）。
  仿照 lerobot_mujoco/asset/example_scene_y.xml，把机器人从 OMY 换成 Panda。

  ⚠️ 使用方法（见 env/README_环境说明.md 详解）：
    1) 把本文件复制到 lerobot_mujoco/asset/ 下（这样下面的 ./tabletop、./objaverse 相对 include 才找得到）。
    2) 把 mujoco_menagerie 的 franka_emika_panda 放到 lerobot_mujoco/asset/franka_panda/。
    3) 在 panda.xml 的 hand body 内补一个名为 tcp_link 的 body 和一个名为 egocentric 的腕部相机。
  agentview / sideview / topview 三个相机来自 object_table.xml，include 即得，无需额外加。
-->
<mujoco model="franka tabletop scene">
  <size memory="500M"/>
  <!-- 不在此声明 <option>: panda.xml 自带 <option integrator="implicitfast">，
       若这里再写一个 <option> 会和它冲突。物理积分器用 panda 的即可。 -->

  <default>
    <joint armature="0.1" damping="0.1"/>
    <default class="visual_only">
      <geom type="mesh" contype="0" conaffinity="0" group="2"/>
    </default>
    <default class="no_visual_collision">
      <geom type="capsule" solimp=".9 .99 .001" solref=".015 1" group="3"/>
    </default>
    <default class="visual_collision">
      <geom type="mesh" solimp=".9 .99 .001" solref=".015 1" group="2"/>
    </default>
  </default>

  <!-- 地面 + 桌子（桌子里自带 agentview / sideview / topview 三个相机），直接复用 lerobot_mujoco 资产 -->
  <include file="./tabletop/object/floor_isaac_style.xml"/>
  <include file="./tabletop/object/object_table.xml"/>

  <!-- Franka Panda：把 mujoco_menagerie 的 franka_emika_panda 放到 ./franka_panda/ 下 -->
  <!-- 需在其 hand body 内补 tcp_link body（末端）与 egocentric 相机（腕部第一人称），见 README -->
  <include file="./franka_panda/panda.xml"/>

  <!-- 桌面物体（body 名沿用 body_obj_ 前缀：env 的随机摆放与成功判定都依赖它）-->
  <include file="./objaverse/mug_5/model_new.xml"/>
  <include file="./objaverse/plate_11/model_new.xml"/>
</mujoco>
